<%- include('../../partials/header', { title, csrfToken, superAdminName }) %>

<div class="page-header">
  <h1>Klienter</h1>
</div>

<div class="content-columns">
  <div class="card">
    <h2 class="card-title">Befintliga klienter</h2>
    <% if (tenants.length === 0) { %>
      <p class="text-muted">Inga klienter ännu.</p>
    <% } else { %>
    <table class="data-table">
      <thead>
        <tr><th>Namn</th><th>Slug</th><th>Status</th><th>E-post</th><th>Admins</th><th>Platser</th><th>Skapad</th><th>Åtgärder</th></tr>
      </thead>
      <tbody>
        <% tenants.forEach(t => { %>
        <tr>
          <td><strong><%= t.name %></strong></td>
          <td class="monospace"><%= t.slug %></td>
          <td><span class="badge <%= t.status === 'active' ? 'badge-green' : 'badge-gray' %>"><%= t.status %></span></td>
          <td><%= t.contact_email || '—' %></td>
          <td><%= t.admin_count %></td>
          <td><%= t.place_count %></td>
          <td><%= new Date(t.created_at).toLocaleDateString('sv-SE') %></td>
          <td class="action-cell">
            <button class="btn btn-xs btn-secondary"
              data-id="<%= t.id %>" data-name="<%= t.name %>"
              data-email="<%= t.contact_email || '' %>" data-status="<%= t.status %>"
              onclick="editTenant(this)">Redigera</button>
            <form method="POST" action="/superadmin/tenants/<%= t.id %>/delete" style="display:inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-xs btn-danger"
                onclick="return confirm('Radera klienten <%= t.name %>? ALL DATA raderas!')">Radera</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <div class="card" id="tenant-form-card">
    <h2 class="card-title" id="tenant-form-title">Ny klient</h2>
    <form method="POST" id="tenant-form" action="/superadmin/tenants">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="form-group">
        <label>Namn <span class="required">*</span></label>
        <input type="text" id="t-name" name="name" required maxlength="255" />
      </div>
      <div class="form-group">
        <label>Kontakt-e-post</label>
        <input type="email" id="t-email" name="contact_email" />
      </div>
      <div class="form-group">
        <label>Status</label>
        <select id="t-status" name="status">
          <option value="active">Aktiv</option>
          <option value="inactive">Inaktiv</option>
        </select>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" id="t-submit">Skapa</button>
        <button type="button" class="btn btn-ghost" id="t-cancel" style="display:none" onclick="resetTenantForm()">Avbryt</button>
      </div>
    </form>
  </div>
</div>

<script>
function editTenant(btn) {
  document.getElementById('tenant-form').action = '/superadmin/tenants/' + btn.dataset.id;
  document.getElementById('t-name').value        = btn.dataset.name;
  document.getElementById('t-email').value       = btn.dataset.email;
  document.getElementById('t-status').value      = btn.dataset.status;
  document.getElementById('t-submit').textContent = 'Spara';
  document.getElementById('t-cancel').style.display = 'inline-flex';
  document.getElementById('tenant-form-title').textContent = 'Redigera klient';
  document.getElementById('tenant-form-card').scrollIntoView({ behavior: 'smooth' });
}
function resetTenantForm() {
  document.getElementById('tenant-form').action = '/superadmin/tenants';
  document.getElementById('tenant-form').reset();
  document.getElementById('t-submit').textContent = 'Skapa';
  document.getElementById('t-cancel').style.display = 'none';
  document.getElementById('tenant-form-title').textContent = 'Ny klient';
}
</script>

  </div>
</main>
<script src="/static/admin/js/admin.js"></script>
</body>
</html>
