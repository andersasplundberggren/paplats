<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Superadmin — GeoExp</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #0d1b2a 0%, #1a2d4a 60%, #0d1b2a 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .card {
      width: 100%;
      max-width: 400px;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      backdrop-filter: blur(12px);
    }

    .badge {
      display: inline-block;
      background: rgba(59, 130, 246, 0.3);
      color: #93c5fd;
      border: 1px solid rgba(59, 130, 246, 0.5);
      border-radius: 99px;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .08em;
      padding: .2rem .75rem;
      margin-bottom: 1.25rem;
    }

    .logo {
      font-size: 2rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: .35rem;
    }

    .subtitle {
      font-size: .85rem;
      color: rgba(255, 255, 255, 0.45);
      margin-bottom: 2rem;
    }

    .error-box {
      background: rgba(220, 38, 38, 0.2);
      border: 1px solid rgba(220, 38, 38, 0.45);
      color: #fca5a5;
      border-radius: 10px;
      padding: .7rem 1rem;
      margin-bottom: 1.25rem;
      font-size: .85rem;
    }

    label {
      display: block;
      font-size: .82rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: .4rem;
    }

    input[type="email"],
    input[type="password"] {
      width: 100%;
      padding: .65rem .85rem;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 10px;
      color: #ffffff;
      font-size: .95rem;
      outline: none;
      transition: border-color .15s;
    }

    input[type="email"]:focus,
    input[type="password"]:focus {
      border-color: rgba(147, 197, 253, 0.6);
      background: rgba(255, 255, 255, 0.13);
    }

    input::placeholder { color: rgba(255,255,255,0.3); }

    .form-group { margin-bottom: 1rem; }

    .btn {
      display: block;
      width: 100%;
      padding: .7rem;
      background: #2563eb;
      color: #ffffff;
      border: none;
      border-radius: 10px;
      font-size: .95rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1.5rem;
      transition: background .15s;
    }

    .btn:hover { background: #1d4ed8; }

    .footer-link {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      color: rgba(255, 255, 255, 0.3);
      font-size: .8rem;
      text-decoration: none;
      transition: color .15s;
    }

    .footer-link:hover { color: rgba(255, 255, 255, 0.6); }
  </style>
</head>
<body>
  <div class="card">
    <div style="text-align:center">
      <span class="badge">SUPERADMIN</span>
      <div class="logo">GeoExp</div>
      <div class="subtitle">Systemadministration</div>
    </div>

    <% if (locals.error && error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form method="POST" action="/superadmin/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="form-group">
        <label for="email">E-post</label>
        <input type="email" id="email" name="email" autocomplete="email" required autofocus placeholder="din@email.se" />
      </div>

      <div class="form-group">
        <label for="password">Lösenord</label>
        <input type="password" id="password" name="password" required placeholder="••••••••••" />
      </div>

      <button type="submit" class="btn">Logga in</button>
    </form>

    <a href="/admin/login" class="footer-link">Vanlig admin-inloggning →</a>
  </div>
</body>
</html>
