<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — GeoExp Admin</title>
  <link rel="stylesheet" href="/static/admin/css/admin.css" />
  <style>
    /* ── Nav reset ───────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }

    .admin-nav {
      display: flex;
      align-items: center;
      gap: 0;
      background: #0f172a;
      border-bottom: 1px solid #1e293b;
      padding: 0 1.5rem;
      height: 56px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-brand a {
      font-size: 1rem;
      font-weight: 700;
      color: #f1f5f9;
      text-decoration: none;
      white-space: nowrap;
      margin-right: 1.5rem;
      letter-spacing: -.01em;
    }

    /* ── Nav groups ──────────────────────────────────────────── */
    .nav-groups {
      display: flex;
      align-items: stretch;
      gap: 0;
      flex: 1;
      height: 100%;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    /* ── Single flat link (Dashboard) ───────────────────────── */
    .nav-item {
      position: relative;
      display: flex;
      align-items: center;
    }

    .nav-item > a,
    .nav-group-btn {
      display: flex;
      align-items: center;
      gap: .35rem;
      padding: 0 .9rem;
      height: 100%;
      font-size: .85rem;
      font-weight: 500;
      color: #94a3b8;
      text-decoration: none;
      white-space: nowrap;
      background: none;
      border: none;
      cursor: pointer;
      transition: color .15s, background .15s;
    }
    .nav-item > a:hover,
    .nav-group-btn:hover,
    .nav-item.active > a,
    .nav-item.active .nav-group-btn {
      color: #f1f5f9;
      background: #1e293b;
    }

    /* ── Dropdown ────────────────────────────────────────────── */
    .nav-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      min-width: 210px;
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 0 0 10px 10px;
      padding: .4rem 0;
      box-shadow: 0 8px 24px rgba(0,0,0,.35);
      list-style: none;
      margin: 0;
    }
    .nav-item:hover .nav-dropdown,
    .nav-item:focus-within .nav-dropdown {
      display: block;
    }

    .nav-dropdown li a {
      display: block;
      padding: .5rem 1.1rem;
      font-size: .83rem;
      color: #94a3b8;
      text-decoration: none;
      transition: color .12s, background .12s;
    }
    .nav-dropdown li a:hover {
      color: #f1f5f9;
      background: #0f172a;
    }
    .nav-dropdown li a .item-icon {
      display: inline-block;
      width: 1.2rem;
      margin-right: .35rem;
      opacity: .7;
    }

    /* Avdelare i dropdown */
    .nav-dropdown .divider {
      border: none;
      border-top: 1px solid #334155;
      margin: .35rem 0;
    }

    /* Kategorirubriker i dropdown */
    .nav-dropdown .group-label {
      padding: .45rem 1.1rem .2rem;
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: #475569;
      pointer-events: none;
    }

    /* Chevron-pil */
    .nav-group-btn .chevron {
      font-size: .65rem;
      margin-left: .1rem;
      opacity: .6;
      transition: transform .15s;
    }
    .nav-item:hover .nav-group-btn .chevron {
      transform: rotate(180deg);
    }

    /* ── Höger-sektion ───────────────────────────────────────── */
    .nav-right {
      display: flex;
      align-items: center;
      gap: .75rem;
      margin-left: auto;
    }
    .nav-tenant {
      font-size: .75rem;
      color: #475569;
      white-space: nowrap;
    }
    .nav-tenant strong { color: #64748b; }
    .nav-role-badge {
      font-size: .68rem;
      padding: .15rem .5rem;
      border-radius: 999px;
      background: #1e293b;
      color: #64748b;
      border: 1px solid #334155;
      white-space: nowrap;
    }
    .btn-link {
      background: none;
      border: none;
      color: #64748b;
      font-size: .82rem;
      cursor: pointer;
      padding: .3rem .6rem;
      border-radius: 6px;
      transition: color .12s, background .12s;
    }
    .btn-link:hover { color: #f87171; background: rgba(248,113,113,.08); }

    /* Impersonerings-banner */
    .impersonation-bar {
      background: #7c3aed;
      color: #fff;
      text-align: center;
      padding: .4rem 1rem;
      font-size: .8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .75rem;
    }
    .impersonation-bar a {
      color: #ddd6fe;
      text-decoration: underline;
      font-weight: 600;
    }
  </style>
</head>
<body>

<!-- Impersonerings-banner (superadmin) -->
<% if (locals.isImpersonating && isImpersonating) { %>
<div class="impersonation-bar">
  ⚡ Du agerar som <strong><%= locals.tenantName || 'tenant' %></strong>.
  <a href="/superadmin/stop-impersonating">Avsluta impersonering</a>
</div>
<% } %>

<nav class="admin-nav">

  <!-- Logotyp -->
  <div class="nav-brand">
    <a href="/admin/dashboard">GeoExp</a>
  </div>

  <ul class="nav-groups">

    <!-- Dashboard (enkel länk) -->
    <li class="nav-item">
      <a href="/admin/dashboard">📊 Dashboard</a>
    </li>

    <!-- ── Platser & Innehåll ─────────────────────────────── -->
    <% if (locals.canCreateDiscoverPlaces || locals.canCreateTrailPlaces) { %>
    <li class="nav-item">
      <button class="nav-group-btn" type="button">
        📍 Platser <span class="chevron">▾</span>
      </button>
      <ul class="nav-dropdown">
        <% if (locals.canCreateDiscoverPlaces) { %>
          <li class="group-label">Innehåll</li>
          <li><a href="/admin/places"><span class="item-icon">🗺️</span>Alla platser</a></li>
          <li><a href="/admin/places/new"><span class="item-icon">➕</span>Ny plats</a></li>
          <li><hr class="divider"></li>
          <li><a href="/admin/collections"><span class="item-icon">📦</span>Samlingar</a></li>
          <li><hr class="divider"></li>
          <li class="group-label">Bibliotek</li>
          <li><a href="/admin/media"><span class="item-icon">🖼️</span>Alla mediafiler</a></li>
          <li><a href="/admin/media/upload"><span class="item-icon">⬆️</span>Ladda upp media</a></li>
          <li><hr class="divider"></li>
          <li><a href="/admin/categories"><span class="item-icon">🏷️</span>Kategorier</a></li>
        <% } else if (locals.canCreateTrailPlaces) { %>
          <!-- Arrangör — kan bara se media -->
          <li><a href="/admin/media"><span class="item-icon">🖼️</span>Alla mediafiler</a></li>
          <li><a href="/admin/media/upload"><span class="item-icon">⬆️</span>Ladda upp media</a></li>
        <% } %>
      </ul>
    </li>
    <% } %>

    <!-- ── Tipspromenader ─────────────────────────────────── -->
    <% if (locals.canCreateTrailPlaces || locals.canCreateDiscoverPlaces) { %>
    <li class="nav-item">
      <button class="nav-group-btn" type="button">
        🚶 Tipspromenader <span class="chevron">▾</span>
      </button>
      <ul class="nav-dropdown">
        <li class="group-label">Hantera</li>
        <li><a href="/admin/trails"><span class="item-icon">📋</span>Alla tipspromenader</a></li>
        <li><a href="/admin/trails/new"><span class="item-icon">➕</span>Ny tipspromenad</a></li>
      </ul>
    </li>
    <% } %>

  </ul>

  <!-- Höger: roll, tenant, logga ut -->
  <div class="nav-right">
    <% if (locals.tenantName) { %>
      <span class="nav-tenant"><strong><%= tenantName %></strong></span>
    <% } %>
    <% if (locals.adminRole) { %>
      <span class="nav-role-badge"><%= adminRole %></span>
    <% } %>
    <form method="POST" action="/admin/logout" style="margin:0">
      <% if (typeof csrfToken !== 'undefined') { %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <% } %>
      <button type="submit" class="btn-link">Logga ut</button>
    </form>
  </div>

</nav>

<main class="main-content">
  <div class="container">
    <% if (locals.success && success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (locals.error && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
