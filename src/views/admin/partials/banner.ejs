<% if (locals.isImpersonating && isImpersonating) { %>
<div style="background:linear-gradient(90deg,#7c3aed,#4f46e5);color:#fff;padding:.6rem 1.5rem;display:flex;align-items:center;justify-content:space-between;font-size:.85rem;position:sticky;top:0;z-index:1000">
  <span>
    👁 Du ser <strong><%= locals.tenantName || 'okänd klient' %></strong> som superadmin
  </span>
  <form method="POST" action="/superadmin/stop-impersonating" style="margin:0">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button type="submit" style="background:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.4);color:#fff;border-radius:6px;padding:.2rem .75rem;cursor:pointer;font-size:.82rem">
      Avsluta impersonering →
    </button>
  </form>
</div>
<% } %>
