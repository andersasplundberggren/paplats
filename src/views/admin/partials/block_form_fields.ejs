<%
/*
  Partial: block_form_fields.ejs
  Placering: src/views/admin/partials/block_form_fields.ejs

  Renderar formulärfält för ett innehållsblock.
  Används både vid skapande (isNew=true, block=null)
  och redigering (isNew=false, block=<objekt>).

  Variabler:
    block       — befintligt block-objekt eller null
    mediaAssets — array av tillgängliga mediafiler
    isNew       — boolean
*/

const b = block || {};
const val = (key, fallback) => {
  const v = b[key];
  return (v !== undefined && v !== null) ? v : (fallback !== undefined ? fallback : '');
};
%>

<%# ─── Gemensamma fält (alltid synliga) ─────────────────── %>
<div data-block-group="common">
  <div class="form-group">
    <label>Titel <span class="label-hint">(valfri rubrik över blocket)</span></label>
    <input type="text" name="title" class="form-input" value="<%= val('title') %>" placeholder="Lämna tom om ingen rubrik önskas">
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>Sorteringsordning</label>
      <input type="number" name="sort_order" class="form-input" value="<%= val('sort_order', 0) %>" min="0" max="999">
    </div>
    <div class="form-group">
      <label>
        <input type="checkbox" name="is_hidden" value="1" <%= val('is_hidden') ? 'checked' : '' %>>
        Dolt block
      </label>
      <p class="field-hint">Dolda block visas inte för användaren förrän de låses upp via logik.</p>
    </div>
  </div>
</div>

<%# ─── Brödtext (text, clue, question, solution, link) ── %>
<div data-block-group="text" data-block-group-also="clue link question solution">
  <div class="form-group">
    <label>Brödtext</label>
    <textarea name="body" class="form-textarea" rows="4" placeholder="Fritext..."><%= val('body') %></textarea>
  </div>
</div>

<%# ─── Mediafil (image, video, audio, ar_overlay) ───────── %>
<div data-block-group="media">
  <div class="form-group">
    <label>Mediafil</label>
    <select name="media_asset_id" class="form-select">
      <option value="">— Ingen mediafil —</option>
      <% mediaAssets.forEach(function(m) { %>
        <option value="<%= m.id %>" <%= val('media_asset_id') == m.id ? 'selected' : '' %>>
          [<%= m.type %>] <%= m.original_filename %>
        </option>
      <% }); %>
    </select>
    <p class="field-hint">Ladda upp filer i <a href="/admin/media" target="_blank">Mediabiblioteket</a> och återvänd hit.</p>
  </div>
</div>

<%# ─── Länkblock ─────────────────────────────────────────── %>
<div data-block-group="link">
  <div class="form-group">
    <label>Länkadress (URL)</label>
    <input type="url" name="cta_url" class="form-input" value="<%= val('cta_url') %>" placeholder="https://...">
  </div>
  <div class="form-group">
    <label>Knapptext</label>
    <input type="text" name="cta_label" class="form-input" value="<%= val('cta_label') %>" placeholder="t.ex. Läs mer">
  </div>
</div>

<%# ─── Frågefält ─────────────────────────────────────────── %>
<div data-block-group="question">
  <hr class="form-divider">
  <p class="form-section-label">Svarsalternativ</p>
  <div class="form-row">
    <div class="form-group">
      <label>Alternativ A</label>
      <input type="text" name="option_a" class="form-input" value="<%= val('option_a') %>">
    </div>
    <div class="form-group">
      <label>Alternativ B</label>
      <input type="text" name="option_b" class="form-input" value="<%= val('option_b') %>">
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Alternativ C <span class="label-hint">(valfri)</span></label>
      <input type="text" name="option_c" class="form-input" value="<%= val('option_c') %>">
    </div>
    <div class="form-group">
      <label>Alternativ D <span class="label-hint">(valfri)</span></label>
      <input type="text" name="option_d" class="form-input" value="<%= val('option_d') %>">
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Rätt alternativ</label>
      <select name="correct_option" class="form-select">
        <option value="">— Välj —</option>
        <% ['a','b','c','d'].forEach(function(opt) { %>
          <option value="<%= opt %>" <%= val('correct_option') === opt ? 'selected' : '' %>><%= opt.toUpperCase() %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Poäng</label>
      <input type="number" name="points" class="form-input" value="<%= val('points', 0) %>" min="0">
    </div>
  </div>
  <div class="form-group">
    <label>Förklaring <span class="label-hint">(visas efter svar)</span></label>
    <textarea name="explanation" class="form-textarea" rows="2"><%= val('explanation') %></textarea>
  </div>
</div>

<%# ─── Lösningsfält ──────────────────────────────────────── %>
<div data-block-group="solution">
  <hr class="form-divider">
  <div class="form-row">
    <div class="form-group">
      <label>Rätt svar</label>
      <input type="text" name="correct_answer" class="form-input" value="<%= val('correct_answer') %>" placeholder="Det exakta svaret">
    </div>
    <div class="form-group">
      <label>Poäng</label>
      <input type="number" name="points" class="form-input" value="<%= val('points', 0) %>" min="0">
    </div>
  </div>
  <div class="form-group">
    <label>Ledtråd <span class="label-hint">(visas för spelaren som hjälp)</span></label>
    <input type="text" name="solution_hint" class="form-input" value="<%= val('solution_hint') %>">
  </div>
  <div class="form-group">
    <label>Förklaring <span class="label-hint">(visas efter rätt svar)</span></label>
    <textarea name="explanation" class="form-textarea" rows="2"><%= val('explanation') %></textarea>
  </div>
</div>

<%# ═══════════════════════════════════════════════════════════ %>
<%# ─── VITTNESBLOCK ──────────────────────────────────────── %>
<%# ═══════════════════════════════════════════════════════════ %>
<div data-block-group="witness">
  <hr class="form-divider">
  <p class="form-section-label">👤 Vittnets uppgifter</p>

  <div class="form-group">
    <label>Namn <span class="label-required">*</span></label>
    <input type="text" name="witness_name" class="form-input"
           value="<%= val('witness_name') %>"
           placeholder="t.ex. Ingrid Holm">
    <p class="field-hint">Personens fullständiga namn.</p>
  </div>

  <div class="form-group">
    <label>Roll eller titel</label>
    <input type="text" name="witness_role" class="form-input"
           value="<%= val('witness_role') %>"
           placeholder="t.ex. Grannfru, plan 3">
    <p class="field-hint">Visas under namnet. Används för att ge kontext utan att avslöja för mycket.</p>
  </div>

  <div class="form-group">
    <label>Uttalande <span class="label-required">*</span></label>
    <textarea name="witness_statement" class="form-textarea" rows="4"
              placeholder="Skriv vad vittnet säger, gärna i första person..."><%= val('witness_statement') %></textarea>
    <p class="field-hint">Uttalandet visas som ett citat i appen. Skriv i första person för bästa effekt. Tänk på om vittnet är pålitligt eller inte — det speglas i tillförlitlighetsmarkeringen.</p>
  </div>

  <div class="form-group">
    <label>Tillförlitlighet</label>
    <select name="witness_reliability" class="form-select">
      <option value="">— Ej angiven —</option>
      <option value="reliable"   <%= val('witness_reliability') === 'reliable'   ? 'selected' : '' %>>✅ Pålitlig</option>
      <option value="uncertain"  <%= val('witness_reliability') === 'uncertain'  ? 'selected' : '' %>>⚠️ Osäker</option>
      <option value="suspicious" <%= val('witness_reliability') === 'suspicious' ? 'selected' : '' %>>🔴 Misstänksam</option>
    </select>
    <p class="field-hint">Visas som en färgad markering i appen. Hjälper spelarna att väga vittnesmålen mot varandra.</p>
  </div>

  <div class="form-group">
    <label>Porträttbild <span class="label-hint">(valfri)</span></label>
    <select name="witness_image_id" class="form-select">
      <option value="">— Ingen bild —</option>
      <% mediaAssets.filter(m => m.type === 'image').forEach(function(m) { %>
        <option value="<%= m.id %>" <%= val('witness_image_id') == m.id ? 'selected' : '' %>>
          <%= m.original_filename %>
        </option>
      <% }); %>
    </select>
    <p class="field-hint">Välj ett porträtt eller en siluett. Behöver inte vara ett verkligt foto — en illustration fungerar lika bra.</p>
  </div>
</div>

<%# ═══════════════════════════════════════════════════════════ %>
<%# ─── BEVISBLOCK ────────────────────────────────────────── %>
<%# ═══════════════════════════════════════════════════════════ %>
<div data-block-group="evidence">
  <hr class="form-divider">
  <p class="form-section-label">📁 Bevisuppgifter</p>

  <div class="form-group">
    <label>Bevismärkning <span class="label-required">*</span></label>
    <input type="text" name="evidence_label" class="form-input"
           value="<%= val('evidence_label') %>"
           placeholder="t.ex. BEVIS A eller FYND 3"
           maxlength="20">
    <p class="field-hint">En kort märkning som visas i bevissamlingen. Håll den kortfattad — max 20 tecken.</p>
  </div>

  <div class="form-group">
    <label>Titel <span class="label-hint">(namn på beviset)</span></label>
    <input type="text" name="title" class="form-input"
           value="<%= val('title') %>"
           placeholder="t.ex. Sönderrivet brev">
    <p class="field-hint">Visas som rubrik i bevissamlingen och i detaljvyn.</p>
  </div>

  <div class="form-group">
    <label>Beskrivning</label>
    <textarea name="body" class="form-textarea" rows="3"
              placeholder="Beskriv vad beviset är och var det hittades..."><%= val('body') %></textarea>
    <p class="field-hint">Synlig beskrivning som spelaren ser direkt.</p>
  </div>

  <div class="form-group">
    <label>Dold detaljbeskrivning <span class="label-hint">(valfri)</span></label>
    <textarea name="evidence_detail" class="form-textarea" rows="3"
              placeholder="En detalj som kräver noggrannare granskning..."><%= val('evidence_detail') %></textarea>
    <p class="field-hint">Visas bakom en "Granska närmare"-knapp i appen. Använd för ledtrådar som belönar uppmärksamma spelare.</p>
  </div>

  <div class="form-group">
    <label>Bevisbilden</label>
    <select name="media_asset_id" class="form-select">
      <option value="">— Ingen bild —</option>
      <% mediaAssets.filter(m => m.type === 'image').forEach(function(m) { %>
        <option value="<%= m.id %>" <%= val('media_asset_id') == m.id ? 'selected' : '' %>>
          <%= m.original_filename %>
        </option>
      <% }); %>
    </select>
    <p class="field-hint">Foto eller illustration av beviset. Visas i bevissamlingen och i detaljvyn.</p>
  </div>
</div>

<%# ─── Initialvärde för dold/synlig-logik ───────────────── %>
<script>
(function() {
  // Dölj alla typspecifika fält initialt
  const container = document.currentScript.parentElement;
  const groups = container.querySelectorAll('[data-block-group]');
  groups.forEach(function(el) {
    const g = el.getAttribute('data-block-group');
    if (g !== 'common') el.style.display = 'none';
  });

  // Hämta aktuell blocktyp från närmaste select
  const form = container.closest('form');
  if (!form) return;
  const typeSelect = form.querySelector('[name="block_type"]');
  if (!typeSelect) return;

  function show(type) {
    groups.forEach(function(el) {
      const g = el.getAttribute('data-block-group');
      if (g === 'common') { el.style.display = ''; return; }
      if (g === type)      { el.style.display = ''; return; }
      if (g === 'media' && ['image','video','audio','ar_overlay'].includes(type)) { el.style.display = ''; return; }
      el.style.display = 'none';
    });
  }

  show(typeSelect.value);
  typeSelect.addEventListener('change', function() { show(this.value); });
})();
</script>
