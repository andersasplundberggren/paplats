<%- include('./impersonation') %>
<nav class="admin-nav">
  <div class="nav-brand">
    <a href="/admin/dashboard">GeoExp Admin</a>
  </div>
  <ul class="nav-links">
    <li><a href="/admin/dashboard">Dashboard</a></li>
    <% if (locals.canCreateDiscoverPlaces) { %>
      <li><a href="/admin/places">Platser</a></li>
      <li><a href="/admin/collections">Samlingar</a></li>
    <% } %>
    <% if (locals.canCreateTrailPlaces) { %>
      <li><a href="/admin/trails">Tipspromenader</a></li>
    <% } %>
    <li><a href="/admin/media">Media</a></li>
    <% if (locals.canCreateDiscoverPlaces) { %>
      <li><a href="/admin/categories">Kategorier</a></li>
    <% } %>
  </ul>
  <div class="nav-user">
    <span style="font-size:.8rem;opacity:.7">
      <%= locals.adminRole === 'redaktor' ? 'Redaktör' : locals.adminRole === 'arrangör' ? 'Arrangör' : locals.adminRole || '' %>
    </span>
    <span><%= locals.adminName || '' %></span>
    <form method="POST" action="/admin/logout" style="display:inline;margin:0">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
      <button type="submit" class="btn-link">Logga ut</button>
    </form>
  </div>
</nav>
