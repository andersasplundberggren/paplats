<%- include('../../partials/header', { title, csrfToken }) %>

<div class="page-header">
  <h1><%= collection.title %></h1>
  <div class="header-actions">
    <code style="background:var(--color-bg);padding:.3rem .75rem;border-radius:6px;font-weight:700;letter-spacing:.08em;border:1px solid var(--color-border)">
      <%= collection.access_code %>
    </code>
    <span class="badge <%= collection.status === 'published' ? 'badge-green' : 'badge-gray' %>">
      <%= collection.status === 'published' ? 'Publicerad' : 'Utkast' %>
    </span>
    <a href="/admin/collections" class="btn btn-ghost btn-sm">← Alla samlingar</a>
  </div>
</div>

<!-- Redigera samling -->
<details class="card" style="margin-bottom:1.5rem">
  <summary style="cursor:pointer;font-weight:600;padding:.75rem 0">Redigera samlingsinformation</summary>
  <form method="POST" action="/admin/collections/<%= collection.id %>" style="margin-top:1rem">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row">
      <div class="form-group">
        <label>Titel</label>
        <input type="text" name="title" value="<%= collection.title %>" required />
      </div>
      <div class="form-group">
        <label>Åtkomstkod</label>
        <input type="text" name="access_code" value="<%= collection.access_code %>"
               style="text-transform:uppercase;font-weight:700" required />
      </div>
      <div class="form-group">
        <label>Status</label>
        <select name="status">
          <option value="draft"     <%= collection.status !== 'published' ? 'selected' : '' %>>Draft</option>
          <option value="published" <%= collection.status === 'published' ? 'selected' : '' %>>Publicerad</option>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>Beskrivning</label>
      <textarea name="description" rows="2"><%= collection.description || '' %></textarea>
    </div>
    <button type="submit" class="btn btn-primary btn-sm">Spara</button>
  </form>
</details>

<div class="content-columns" style="grid-template-columns:1fr 360px">

  <!-- Kopplade platser -->
  <div class="card">
    <h2 class="card-title">Platser i samlingen (<%= attached.length %>)</h2>
    <% if (attached.length === 0) { %>
      <p class="text-muted">Inga platser tillagda ännu. Lägg till platser från listan till höger.</p>
    <% } else { %>
    <table class="data-table">
      <thead>
        <tr><th>Ordning</th><th>Plats</th><th>Status</th><th>Synlighet</th><th>Åtgärder</th></tr>
      </thead>
      <tbody>
        <% attached.forEach(p => { %>
        <tr>
          <td><%= p.display_order %></td>
          <td>
            <strong><%= p.title %></strong>
            <% if (p.short_description) { %>
              <div style="font-size:.78rem;color:var(--color-muted)"><%= p.short_description %></div>
            <% } %>
          </td>
          <td><span class="badge <%= p.status === 'published' ? 'badge-green' : 'badge-gray' %>"><%= p.status %></span></td>
          <td><span class="badge <%= p.visibility === 'discover' ? 'badge-blue' : 'badge-orange' %>"><%= p.visibility %></span></td>
          <td class="action-cell">
            <form method="POST" action="/admin/collections/<%= collection.id %>/places/<%= p.cp_id %>/delete">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-xs btn-danger"
                onclick="return confirm('Ta bort <%= p.title %> från samlingen?')">Ta bort</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- Lägg till plats -->
  <div class="card" style="position:sticky;top:1rem">
    <h3 style="font-size:.95rem;font-weight:600;margin-bottom:1rem">Lägg till plats</h3>
    <% if (available.length === 0) { %>
      <p class="text-muted" style="font-size:.85rem">
        Alla publicerade platser är redan tillagda, eller så finns inga platser med synlighet "discover".
        <a href="/admin/places">Hantera platser →</a>
      </p>
    <% } else { %>
    <form method="POST" action="/admin/collections/<%= collection.id %>/places">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="form-group">
        <label style="font-size:.82rem">Välj plats</label>
        <select name="place_id" required style="width:100%;padding:.45rem;border:1px solid var(--color-border);border-radius:6px">
          <option value="">— Välj plats —</option>
          <% available.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.title %> (<%= p.visibility %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label style="font-size:.82rem">Visningsordning</label>
        <input type="number" name="display_order" value="<%= attached.length %>"
               style="width:100%;padding:.45rem;border:1px solid var(--color-border);border-radius:6px" />
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%">+ Lägg till plats</button>
    </form>
    <% } %>
    <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--color-border);font-size:.78rem;color:var(--color-muted)">
      <strong>Tips:</strong> Enbart platser med synlighet <strong>discover</strong> visas i Upptäck-läget.
      Platser med synlighet <strong>trail_only</strong> syns bara i tipspromenader.
      <a href="/admin/places" style="display:block;margin-top:.5rem">Ändra synlighet på platser →</a>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
