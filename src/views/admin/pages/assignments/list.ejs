<%- include('../../partials/header', { title, csrfToken }) %>

<div class="page-header">
  <h1>Uppdrag
    <% if (typeof helpIcon !== 'undefined') { %><%- helpIcon('assignments') %><% } %>
  </h1>
  <div class="header-actions">
    <% if (locals.adminRole === 'admin' || locals.adminRole === 'systemadmin') { %>
      <a href="/admin/assignments/new" class="btn btn-primary">+ Nytt uppdrag</a>
    <% } %>
  </div>
</div>

<%
function assignmentIcon(type) {
  switch(type) {
    case 'exploration':   return '🗺️';
    case 'trail':         return '🚶';
    case 'mystery':       return '🔍';
    case 'treasure_hunt': return '🔍';
    case 'quiz_walk':     return '📋';
    case 'digital':       return '⚡';
    default:              return '📍';
  }
}
function assignmentTypeName(type) {
  switch(type) {
    case 'exploration':   return 'Utforskning';
    case 'trail':         return 'Tipspromenad';
    case 'mystery':       return 'Gåta';
    case 'treasure_hunt': return 'Skattjakt';
    case 'quiz_walk':     return 'Frågepromenad';
    case 'digital':       return 'Digitalt';
    default:              return type || 'Okänd';
  }
}
%>

<% if (assignments.length === 0) { %>
  <div class="card" style="text-align:center;padding:3rem">
    <p style="color:var(--color-muted);margin-bottom:1.5rem">Inga uppdrag skapade ännu.</p>
    <% if (locals.adminRole === 'admin' || locals.adminRole === 'systemadmin') { %>
      <a href="/admin/assignments/new" class="btn btn-primary">Skapa första uppdraget</a>
    <% } %>
  </div>
<% } else { %>
  <div style="display:grid;gap:1rem">
    <% assignments.forEach(a => { %>
    <div class="card" style="display:flex;align-items:center;gap:1.5rem;padding:1.25rem 1.5rem">

      <!-- Typ-ikon -->
      <div style="font-size:2rem;flex-shrink:0" title="<%= assignmentTypeName(a.type) %>">
        <%= assignmentIcon(a.type) %>
      </div>

      <!-- Info -->
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.3rem;flex-wrap:wrap">
          <strong style="font-size:1.05rem"><%= a.title %></strong>
          <span class="badge <%= a.status === 'published' ? 'badge-green' : 'badge-gray' %>">
            <%= a.status === 'published' ? 'Publicerad' : 'Utkast' %>
          </span>
          <code style="font-size:.78rem;padding:.15rem .5rem;background:var(--color-bg);border:1px solid var(--color-border);border-radius:5px"
                title="Åtkomstkod — användaren anger denna i appen">
            <%= a.access_code %>
          </code>
        </div>
        <div style="font-size:.8rem;color:var(--color-muted);display:flex;gap:1.25rem;flex-wrap:wrap">
          <span><%= assignmentTypeName(a.type) %></span>
          <span><%= a.place_count %> plats<%= a.place_count === 1 ? '' : 'er' %></span>
          <span><%= a.session_count %> session<%= a.session_count === 1 ? '' : 'er' %></span>
          <% if (a.activation_starts_at || a.activation_ends_at) { %>
            <span>
              <% if (a.activation_starts_at) { %>Från <%= new Date(a.activation_starts_at).toLocaleDateString('sv-SE') %><% } %>
              <% if (a.activation_ends_at) { %> till <%= new Date(a.activation_ends_at).toLocaleDateString('sv-SE') %><% } %>
            </span>
          <% } %>
        </div>
      </div>

      <!-- Knappar -->
      <div style="display:flex;align-items:center;gap:.4rem;flex-shrink:0">
        <!-- Primär: hantera platser och innehåll -->
        <a href="/admin/assignments/<%= a.id %>/places"
           class="btn btn-primary btn-sm"
           title="Hantera platserna i det här uppdraget — lägg till, redigera och ordna platser">
          Hantera platser
        </a>
        <a href="/admin/assignments/<%= a.id %>/edit"
           class="btn btn-ghost btn-sm"
           title="Redigera uppdragets titel, åtkomstkod och inställningar">
          Redigera
        </a>
        <% if (a.preview_token) { %>
        <div style="width:1px;height:1.4rem;background:var(--color-border);margin:0 .1rem"></div>
        <a href="/app/preview/?preview=<%= a.preview_token %>"
           target="_blank"
           class="btn btn-ghost btn-sm"
           title="Förhandsgranska uppdraget i appen utan GPS-krav — öppnas i ny flik">
          Förhandsgranska ↗
        </a>
        <% } %>
        <% if (locals.adminRole === 'admin' || locals.adminRole === 'systemadmin') { %>
        <div style="width:1px;height:1.4rem;background:var(--color-border);margin:0 .1rem"></div>
        <form method="POST" action="/admin/assignments/<%= a.id %>/copy" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-ghost btn-sm"
            title="Skapa en kopia av uppdraget med alla platser och allt innehåll"
            onclick="return confirm('Kopiera uppdraget \'<%= a.title %>\' med alla platser och innehåll?')">
            Kopiera
          </button>
        </form>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
<% } %>

<%- include('../../partials/footer') %>

