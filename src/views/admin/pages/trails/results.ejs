<%- include('../../partials/header', { title, csrfToken }) %>

<div class="page-header">
  <h1>Resultat — <%= trail.title %></h1>
  <div class="header-actions">
    <a href="/admin/trails/<%= trail.id %>/stops" class="btn btn-ghost">← Tillbaka</a>
  </div>
</div>

<div class="card" style="margin-bottom:1.5rem">
  <h2 class="card-title">Publik resultatlänk</h2>
  <p style="font-size:.85rem;color:var(--color-muted);margin-bottom:.75rem">
    Dela denna länk — ingen inloggning krävs för att se resultaten.
  </p>
  <div style="display:flex;gap:.5rem;align-items:center">
    <code style="background:var(--color-bg);padding:.5rem .75rem;border-radius:6px;border:1px solid var(--color-border);font-size:.82rem;flex:1;word-break:break-all">
      <%= baseUrl %>/results/trails/<%= trail.results_token %>
    </code>
    <button
      onclick="navigator.clipboard.writeText('<%= baseUrl %>/results/trails/<%= trail.results_token %>').then(() => { this.textContent = 'Kopierad ✓'; setTimeout(() => this.textContent = 'Kopiera', 2000); })"
      class="btn btn-secondary btn-sm">Kopiera</button>
    <a href="/results/trails/<%= trail.results_token %>" target="_blank" class="btn btn-ghost btn-sm">Öppna ↗</a>
  </div>
</div>

<div class="card">
  <h2 class="card-title">Deltagare (<%= sessions.length %>)</h2>

  <% if (sessions.length === 0) { %>
    <p class="text-muted">Inga deltagare har slutfört promenaden ännu.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Namn</th>
          <th>Kontaktuppgift</th>
          <th>Startade</th>
          <th>Avslutade</th>
          <th>Svar</th>
          <th>Poäng</th>
        </tr>
      </thead>
      <tbody>
        <% sessions.forEach(s => { %>
        <tr>
          <td><strong><%= s.nickname || 'Anonym' %></strong></td>
          <td><%= s.contact || '—' %></td>
          <td style="font-size:.82rem"><%= new Date(s.started_at).toLocaleString('sv-SE') %></td>
          <td style="font-size:.82rem">
            <% if (s.completed_at) { %>
              <span style="color:#16a34a">✓ <%= new Date(s.completed_at).toLocaleString('sv-SE') %></span>
            <% } else { %>
              <span class="text-muted">Ej klar</span>
            <% } %>
          </td>
          <td><%= s.answer_count %></td>
          <td><strong><%= s.total_score || 0 %> p</strong></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('../../partials/footer') %>
