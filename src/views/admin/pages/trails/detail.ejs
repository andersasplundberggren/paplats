<%- include('../../partials/header', { title, csrfToken }) %>

<div class="page-header">
  <h1><%= trail.title %></h1>
  <div class="header-actions">
    <a href="/admin/trails/<%= trail.id %>/stops" class="btn btn-primary">Redigera stopp</a>
    <a href="/admin/trails/<%= trail.id %>/edit" class="btn btn-ghost">Inställningar</a>
    <a href="/admin/trails" class="btn btn-ghost">← Alla promenader</a>
  </div>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:2rem">

  <div>
    <div class="card" style="margin-bottom:1.5rem">
      <h2 class="card-title">Beskrivning</h2>
      <p><%= trail.description || 'Ingen beskrivning.' %></p>
    </div>

    <div class="card">
      <h2 class="card-title">Stopp (<%= stops.length %>)</h2>
      <% if (stops.length === 0) { %>
        <p class="text-muted">Inga stopp tillagda ännu.</p>
      <% } else { %>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <% stops.forEach((stop, i) => { %>
          <div style="display:flex;gap:1rem;padding:1rem;background:var(--color-bg);border-radius:8px">
            <div style="background:var(--color-primary);color:#fff;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0">
              <%= i + 1 %>
            </div>
            <div style="flex:1">
              <strong><%= stop.place_title %></strong>
              <div style="font-size:.82rem;color:var(--color-muted);margin-top:.2rem">
                Radius: <%= stop.activation_radius_meters %> m
              </div>
              <% if (stop.intro_text) { %>
                <p style="font-size:.85rem;margin-top:.5rem;font-style:italic"><%= stop.intro_text %></p>
              <% } %>
              <% if (stop.question_text) { %>
                <div style="margin-top:.75rem;padding:.75rem;background:var(--color-surface);border-radius:6px;border:1px solid var(--color-border)">
                  <strong style="font-size:.82rem">❓ <%= stop.question_text %></strong>
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:.35rem;margin-top:.5rem">
                    <% ['a','b','c','d'].forEach(opt => { %>
                      <% if (stop['option_' + opt]) { %>
                        <div style="font-size:.8rem;padding:.25rem .5rem;border-radius:4px;
                          background:<%= stop.correct_option === opt ? 'rgba(34,197,94,0.15)' : 'transparent' %>;
                          border:1px solid <%= stop.correct_option === opt ? 'rgba(34,197,94,0.4)' : 'var(--color-border)' %>">
                          <strong><%= opt.toUpperCase() %>.</strong> <%= stop['option_' + opt] %>
                          <% if (stop.correct_option === opt) { %> ✓<% } %>
                        </div>
                      <% } %>
                    <% }) %>
                  </div>
                  <% if (stop.explanation) { %>
                    <p style="font-size:.78rem;color:var(--color-muted);margin-top:.5rem">
                      💡 <%= stop.explanation %>
                    </p>
                  <% } %>
                  <div style="font-size:.78rem;color:var(--color-muted);margin-top:.35rem">
                    Poäng: <%= stop.points || 10 %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <div>
    <div class="card" style="margin-bottom:1rem">
      <h2 class="card-title">Info</h2>
      <dl style="display:grid;row-gap:.6rem">
        <div>
          <dt style="font-size:.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em">Åtkomstkod</dt>
          <dd><code style="font-weight:700;font-size:1rem;letter-spacing:.08em"><%= trail.access_code %></code></dd>
        </div>
        <div>
          <dt style="font-size:.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em">Status</dt>
          <dd><span class="badge <%= trail.status === 'published' ? 'badge-green' : 'badge-gray' %>"><%= trail.status %></span></dd>
        </div>
        <div>
          <dt style="font-size:.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em">Rättningsläge</dt>
          <dd><span class="badge badge-blue"><%= trail.grading_mode === 'auto' ? 'Självrätt.' : 'Insamlad' %></span></dd>
        </div>
        <div>
          <dt style="font-size:.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em">Svårighetsgrad</dt>
          <dd><%= trail.difficulty === 'easy' ? 'Lätt' : trail.difficulty === 'medium' ? 'Medel' : 'Svår' %></dd>
        </div>
        <% if (trail.estimated_minutes) { %>
        <div>
          <dt style="font-size:.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em">Uppskattad tid</dt>
          <dd><%= trail.estimated_minutes %> min</dd>
        </div>
        <% } %>
        <div>
          <dt style="font-size:.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em">Skapad</dt>
          <dd><%= new Date(trail.created_at).toLocaleDateString('sv-SE') %></dd>
        </div>
      </dl>
    </div>

    <div class="card">
      <h2 class="card-title">Åtgärder</h2>
      <div style="display:flex;flex-direction:column;gap:.5rem">
        <a href="/admin/trails/<%= trail.id %>/stops" class="btn btn-primary">Redigera stopp och frågor</a>
        <a href="/admin/trails/<%= trail.id %>/edit" class="btn btn-secondary">Redigera inställningar</a>
        <% if (trail.grading_mode === 'collected') { %>
          <a href="/admin/trails/<%= trail.id %>/results" class="btn btn-secondary">Se insamlade svar</a>
        <% } %>
        <form method="POST" action="/admin/trails/<%= trail.id %>/publish">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn <%= trail.status === 'published' ? 'btn-ghost' : 'btn-primary' %>" style="width:100%">
            <%= trail.status === 'published' ? 'Avpublicera' : 'Publicera' %>
          </button>
        </form>
        <form method="POST" action="/admin/trails/<%= trail.id %>/delete">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-danger" style="width:100%"
            onclick="return confirm('Radera promenaden permanent?')">Radera promenad</button>
        </form>
      </div>
    </div>
  </div>

</div>

<%- include('../../partials/footer') %>
