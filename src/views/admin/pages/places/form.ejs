<%- include('../../partials/header', { title, csrfToken }) %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style>
  #map-picker { height:400px;border-radius:10px;border:2px solid var(--color-border,#e2e8f0);z-index:1; }
  #map-picker.has-marker { border-color:var(--color-primary,#3b82f6); }
  .map-search-wrap { position:relative;margin-bottom:.6rem; }
  #map-search { width:100%;padding:.55rem 3.5rem .55rem .9rem;border:1px solid var(--color-border,#e2e8f0);border-radius:8px;font-size:.9rem;box-sizing:border-box; }
  #map-search-btn { position:absolute;right:.4rem;top:50%;transform:translateY(-50%);background:var(--color-primary,#3b82f6);color:#fff;border:none;border-radius:6px;padding:.3rem .75rem;font-size:.8rem;cursor:pointer; }
  .coord-fields { display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:.75rem; }
</style>

<div class="page-header">
  <h1><%= place ? 'Redigera plats' : 'Ny plats' %></h1>
  <div class="header-actions">
    <% if (assignment) { %>
      <a href="/admin/assignments/<%= assignment.id %>/places" class="btn btn-ghost">← <%= assignment.title %></a>
    <% } %>
    <% if (place) { %>
      <a href="/admin/content/<%= place.id %>" class="btn btn-secondary">Hantera innehåll</a>
    <% } %>
  </div>
</div>

<form method="POST" action="<%= place ? '/admin/places/' + place.id : '/admin/places' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <% if (!place && assignment) { %>
    <input type="hidden" name="assignment_id" value="<%= assignment.id %>" />
  <% } %>

  <div class="content-columns">
    <div>

      <div class="card" style="margin-bottom:1.5rem">
        <h2 class="card-title">Grundinformation</h2>
        <div class="form-group">
          <label>Titel <span class="required">*</span></label>
          <input type="text" name="title" required maxlength="255"
                 value="<%= (place && place.title) || '' %>" />
        </div>
        <div class="form-group">
          <label>Kort beskrivning</label>
          <input type="text" name="short_description" maxlength="500"
                 value="<%= (place && place.short_description) || '' %>" />
        </div>
        <div class="form-group">
          <label>Lång beskrivning</label>
          <textarea name="long_description" rows="4"><%= (place && place.long_description) || '' %></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Kategori</label>
            <select name="category_id">
              <option value="">— Ingen —</option>
              <% if (categories) { categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= place && place.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
              <% }) } %>
            </select>
          </div>
          <div class="form-group">
            <label>Sorteringsordning</label>
            <input type="number" name="stop_order"
                   value="<%= (place && place.stop_order != null) ? place.stop_order : 0 %>" />
          </div>
        </div>
      </div>

      <!-- KARTVÄLJARE -->
      <div class="card" style="margin-bottom:1.5rem" id="map-card">
        <h2 class="card-title">Placering på karta</h2>

        <% if (assignment && assignment.type === 'digital') { %>
          <div class="field-help" style="margin-bottom:1rem">
            ⚡ Det här uppdraget är av typen <strong>Digital</strong> — platser är steg utan fysisk position.
            Koordinater är valfritt och används bara om du vill visa platsen på en karta.
          </div>
        <% } %>

        <div class="map-search-wrap">
          <input type="text" id="map-search" placeholder="Sök adress, t.ex. Stortorget Karlskoga…" />
          <button type="button" id="map-search-btn">Sök</button>
        </div>
        <div id="map-picker"></div>
        <p id="map-hint" style="font-size:.78rem;color:var(--color-muted);margin-top:.4rem">
          <% if (place && place.latitude && place.longitude) { %>
            Markör placerad — klicka på kartan eller dra markören för att flytta
          <% } else if (assignment && assignment.type === 'digital') { %>
            Valfritt — lämna tomt om platsen inte har en fysisk position
          <% } else { %>
            Klicka på kartan för att placera platsen, eller sök efter adress ovan
          <% } %>
        </p>
        <div class="coord-fields">
          <div>
            <label style="font-size:.8rem;font-weight:600;display:block;margin-bottom:.25rem">
              Latitud
              <% if (!(assignment && assignment.type === 'digital')) { %><span class="required">*</span><% } %>
              <% if (assignment && assignment.type === 'digital') { %><span class="hint">valfritt</span><% } %>
            </label>
            <input type="number" id="lat-input" name="latitude" step="any" min="55" max="69"
                   <%= !(assignment && assignment.type === 'digital') ? 'required' : '' %>
                   value="<%= (place && place.latitude) ? parseFloat(place.latitude) : '' %>"
                   placeholder="<%= (assignment && assignment.type === 'digital') ? 'Lämna tomt om ej tillämpligt' : '59.325399' %>"
                   oninput="onCoordInput()"
                   style="width:100%;padding:.45rem .6rem;border:1px solid var(--color-border,#e2e8f0);border-radius:6px" />
          </div>
          <div>
            <label style="font-size:.8rem;font-weight:600;display:block;margin-bottom:.25rem">
              Longitud
              <% if (!(assignment && assignment.type === 'digital')) { %><span class="required">*</span><% } %>
              <% if (assignment && assignment.type === 'digital') { %><span class="hint">valfritt</span><% } %>
            </label>
            <input type="number" id="lng-input" name="longitude" step="any" min="10" max="25"
                   <%= !(assignment && assignment.type === 'digital') ? 'required' : '' %>
                   value="<%= (place && place.longitude) ? parseFloat(place.longitude) : '' %>"
                   placeholder="<%= (assignment && assignment.type === 'digital') ? 'Lämna tomt om ej tillämpligt' : '15.442078' %>"
                   oninput="onCoordInput()"
                   style="width:100%;padding:.45rem .6rem;border:1px solid var(--color-border,#e2e8f0);border-radius:6px" />
          </div>
        </div>
        <div class="form-row" style="margin-top:1rem">
          <div class="form-group">
            <label>
              Aktiveringsradie (meter)
              <% if (assignment && assignment.type === 'digital') { %><span class="hint">valfritt</span><% } %>
            </label>
            <input type="number" name="activation_radius_meters" id="radius-input" min="1" max="10000"
                   value="<%= (place && place.activation_radius_meters) ? place.activation_radius_meters : (assignment && assignment.type === 'digital' ? '' : 50) %>"
                   placeholder="<%= (assignment && assignment.type === 'digital') ? 'Lämna tomt' : '50' %>"
                   oninput="updateRadiusCircle()" />
          </div>
          <div class="form-group">
            <label>Önskad riktning (°) <span class="hint">valfritt</span></label>
            <input type="number" name="preferred_bearing_degrees" min="0" max="360" step="1"
                   value="<%= (place && place.preferred_bearing_degrees) || '' %>"
                   placeholder="90 = öst" />
          </div>
        </div>
      </div>

      <!-- Linjär upplåsning -->
      <% if (assignment && assignment.unlock_mode === 'linear' && existingPlaces && existingPlaces.length > 0) { %>
      <div class="card" style="margin-bottom:1.5rem">
        <h2 class="card-title">Linjär upplåsning</h2>
        <div class="form-group">
          <label>Låses upp efter</label>
          <select name="unlocks_after_place_id">
            <option value="">— Inget krav (kan besökas direkt) —</option>
            <% existingPlaces.forEach(p => { %>
              <option value="<%= p.id %>" <%= place && place.unlocks_after_place_id == p.id ? 'selected' : '' %>>
                Stopp <%= p.stop_order %>: <%= p.title %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Tidsstyrd upplåsning <span class="hint">valfritt</span></label>
          <input type="datetime-local" name="unlocks_at"
                 value="<%= (place && place.unlocks_at) ? new Date(place.unlocks_at).toISOString().slice(0,16) : '' %>" />
        </div>
      </div>
      <% } %>

    </div>

    <!-- Höger kolumn -->
    <div>
      <div class="card" style="margin-bottom:1rem">
        <h2 class="card-title">Status</h2>
        <div class="form-group">
          <select name="status">
            <option value="draft"     <%= !place || place.status !== 'published' ? 'selected' : '' %>>Utkast</option>
            <option value="published" <%=  place && place.status === 'published'  ? 'selected' : '' %>>Publicerad</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">
          <%= place ? 'Spara ändringar' : 'Skapa plats' %>
        </button>
      </div>
      <% if (place) { %>
      <div class="card">
        <h2 class="card-title">Innehåll</h2>
        <a href="/admin/content/<%= place.id %>" class="btn btn-secondary" style="width:100%;text-align:center;display:block">
          Hantera innehållsblock →
        </a>
      </div>
      <% } %>
    </div>
  </div>
</form>
<% if (place) { %>
<form method="POST" action="/admin/places/<%= place.id %>/delete" style="margin-top:.5rem">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <button type="submit" class="btn btn-danger" style="width:100%"
    onclick="return confirm('Vill du verkligen radera platsen \'<%= place.title %>\' permanent? Åtgärden kan inte ångras.')">Radera plats</button>
</form>
<% } %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
const initLat = <%= (place && place.latitude)  ? parseFloat(place.latitude)  : 'null' %>;
const initLng = <%= (place && place.longitude) ? parseFloat(place.longitude) : 'null' %>;
const initR   = <%= (place && place.activation_radius_meters) ? parseInt(place.activation_radius_meters) : 50 %>;

const map = L.map('map-picker');
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© OpenStreetMap', maxZoom: 19
}).addTo(map);

let marker = null, circle = null;

function placeMarker(lat, lng, r) {
  if (isNaN(lat) || isNaN(lng)) return;
  if (marker) { marker.setLatLng([lat, lng]); }
  else {
    marker = L.marker([lat, lng], { draggable: true }).addTo(map);
    marker.on('dragend', e => { const p = e.target.getLatLng(); setCoords(p.lat, p.lng); updateRadiusCircle(); });
  }
  const radius = parseInt(r) || 50;
  if (circle) { circle.setLatLng([lat, lng]); circle.setRadius(radius); }
  else { circle = L.circle([lat, lng], { radius, color:'#3b82f6', fillColor:'#3b82f6', fillOpacity:.12, weight:2 }).addTo(map); }
  document.getElementById('map-picker').classList.add('has-marker');
}

function setCoords(lat, lng) {
  document.getElementById('lat-input').value = parseFloat(lat).toFixed(7);
  document.getElementById('lng-input').value = parseFloat(lng).toFixed(7);
}

function updateRadiusCircle() {
  const r = parseInt(document.getElementById('radius-input').value) || 50;
  if (circle) circle.setRadius(r);
}

function onCoordInput() {
  const lat = parseFloat(document.getElementById('lat-input').value);
  const lng = parseFloat(document.getElementById('lng-input').value);
  if (!isNaN(lat) && !isNaN(lng) && lat >= 40 && lat <= 80 && lng >= -30 && lng <= 50) {
    placeMarker(lat, lng, document.getElementById('radius-input').value);
    if (map.getZoom() < 12) map.setView([lat, lng], 16);
    else map.setView([lat, lng], map.getZoom());
  }
}

map.on('click', e => {
  setCoords(e.latlng.lat, e.latlng.lng);
  placeMarker(e.latlng.lat, e.latlng.lng, document.getElementById('radius-input').value);
});

async function searchAddress() {
  const q = document.getElementById('map-search').value.trim();
  if (!q) return;
  const btn = document.getElementById('map-search-btn');
  btn.textContent = '…'; btn.disabled = true;
  try {
    const res  = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(q)}&limit=1`, {
      headers: { 'Accept-Language': 'sv', 'User-Agent': 'GeoExpAdmin/1.0' }
    });
    const data = await res.json();
    if (!data.length) { alert('Ingen plats hittades.'); }
    else {
      const lat = parseFloat(data[0].lat), lng = parseFloat(data[0].lon);
      setCoords(lat, lng);
      placeMarker(lat, lng, document.getElementById('radius-input').value);
      map.setView([lat, lng], 16);
    }
  } catch(e) { alert('Sökning misslyckades.'); }
  finally { btn.textContent = 'Sök'; btn.disabled = false; }
}

document.getElementById('map-search-btn').addEventListener('click', searchAddress);
document.getElementById('map-search').addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); searchAddress(); } });

if (initLat && initLng) { map.setView([initLat, initLng], 16); placeMarker(initLat, initLng, initR); }
else { map.setView([62.5, 16.0], 5); }
setTimeout(() => map.invalidateSize(), 100);
</script>

<%- include('../../partials/footer') %>
